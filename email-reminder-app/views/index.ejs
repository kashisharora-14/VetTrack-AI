<% 
let body = `
<div class="card">
    <div class="card-header text-center">
        <h3 class="mb-0">
            <i class="fas fa-clock me-2"></i>
            Daily Reminder Setup
        </h3>
    </div>
    <div class="card-body">
        ${userEmail ? `
            <!-- User has email configured -->
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Email configured:</strong> ${userEmail}
            </div>
            
            <!-- Statistics -->
            ${stats ? `
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="stats-card p-3 text-center">
                            <i class="fas fa-paper-plane fa-2x mb-2"></i>
                            <h4>${stats.totalSent || 0}</h4>
                            <small>Total Reminders Sent</small>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="stats-card p-3 text-center">
                            <i class="fas fa-calendar-check fa-2x mb-2"></i>
                            <h6>${stats.lastSent ? new Date(stats.lastSent).toLocaleDateString() : 'Never'}</h6>
                            <small>Last Reminder Sent</small>
                        </div>
                    </div>
                </div>
            ` : ''}
            
            <!-- Cron Status -->
            ${cronStatus ? `
                <div class="alert ${cronStatus.isRunning ? 'alert-success' : 'alert-warning'}">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas ${cronStatus.isRunning ? 'fa-play-circle' : 'fa-pause-circle'} me-2"></i>
                            <strong>Scheduler Status:</strong> ${cronStatus.isRunning ? 'Running' : 'Stopped'}
                            ${cronStatus.nextExecution ? `<br><small>Next reminder: ${cronStatus.nextExecution}</small>` : ''}
                        </div>
                        <div>
                            ${cronStatus.isRunning ? `
                                <button class="btn btn-sm btn-warning" onclick="toggleCron('stop')">
                                    <i class="fas fa-stop me-1"></i>Stop
                                </button>
                            ` : `
                                <button class="btn btn-sm btn-success" onclick="toggleCron('start')">
                                    <i class="fas fa-play me-1"></i>Start
                                </button>
                            `}
                        </div>
                    </div>
                </div>
            ` : ''}
            
            <!-- Action Buttons -->
            <div class="row">
                <div class="col-md-6 mb-2">
                    <button class="btn btn-primary w-100" onclick="sendTestEmail()">
                        <i class="fas fa-paper-plane me-2"></i>
                        Send Test Reminder
                    </button>
                </div>
                <div class="col-md-6 mb-2">
                    <a href="/update-email" class="btn btn-outline-primary w-100">
                        <i class="fas fa-edit me-2"></i>
                        Update Email
                    </a>
                </div>
            </div>
        ` : `
            <!-- User needs to set email -->
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Welcome! Please enter your email address to start receiving daily reminders.
            </div>
            
            <form id="emailForm">
                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-envelope"></i>
                        </span>
                        <input type="email" class="form-control" id="email" name="email" required 
                               placeholder="your-email@example.com">
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-save me-2"></i>
                    Save Email & Start Reminders
                </button>
            </form>
        `}
        
        <!-- Information Section -->
        <div class="mt-4">
            <h5><i class="fas fa-question-circle me-2"></i>How it works:</h5>
            <ul class="list-unstyled">
                <li><i class="fas fa-check text-success me-2"></i>Enter your email address</li>
                <li><i class="fas fa-check text-success me-2"></i>Receive daily motivational reminders at 9:00 AM</li>
                <li><i class="fas fa-check text-success me-2"></i>Track your goals and stay motivated</li>
                <li><i class="fas fa-check text-success me-2"></i>Update your email anytime</li>
            </ul>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const emailForm = document.getElementById('emailForm');
    if (emailForm) {
        emailForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            
            // Show loading state
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Saving...';
            submitBtn.disabled = true;
            
            try {
                const response = await makeRequest('/set-email', {
                    method: 'POST',
                    body: JSON.stringify({ email })
                });
                
                if (response.success) {
                    showNotification(response.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification(response.message, 'error');
                }
            } catch (error) {
                showNotification('Failed to save email. Please try again.', 'error');
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });
    }
});

async function sendTestEmail() {
    const btn = event.target;
    const originalText = btn.innerHTML;
    
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sending...';
    btn.disabled = true;
    
    try {
        const response = await makeRequest('/send-test', { method: 'POST' });
        
        if (response.success) {
            showNotification(response.message, 'success');
        } else {
            showNotification(response.message, 'error');
        }
    } catch (error) {
        showNotification('Failed to send test email. Please try again.', 'error');
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}

async function toggleCron(action) {
    const btn = event.target;
    const originalText = btn.innerHTML;
    
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>...';
    btn.disabled = true;
    
    try {
        const response = await makeRequest(\`/cron/\${action}\`, { method: 'POST' });
        
        if (response.success) {
            showNotification(response.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showNotification(response.message, 'error');
        }
    } catch (error) {
        showNotification(\`Failed to \${action} scheduler. Please try again.\`, 'error');
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}
</script>
`;

let page = 'home';
let title = 'Daily Reminder App - Home';
%>

<%- include('layout', { body, page, title }) %>